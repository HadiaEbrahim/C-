using System;
using System.Collections.Generic;
using System.Diagnostics.Metrics;
using System.Linq;
using System.Text;
class UserAccount
{
     private string  _name;
    private string _password;
    private string _email;

    public string Name { 
        get { return _name; } 
       
    }
    public string email { 
        get { return _email; } 
       
    }
    public UserAccount(string name, string password, string email)
    {
        if (string.IsNullOrEmpty(name))
        {
            throw new ArgumentException("Name cannot be null or empty.");
        }
        if (string.IsNullOrEmpty(password))
        {
            throw new ArgumentException("Password cannot be null or empty.");
        }
        if (!string.IsNullOrEmpty(email) || !email.Contains("@") || !email.Contains(".com")) {
            throw new ArgumentException("invalid email format.");
        }
        this._name = name;
        this._password = password;
        this._email = email;
    }
    public void ChangePassword(string newPassword,string oldPassword)
    {
        if (string.IsNullOrEmpty(newPassword))
        {
            throw new ArgumentException("New password cannot be null or empty.");
        }
        if(oldPassword != this._password)   
        {
            throw new ArgumentException("Old password is incorrect.");
        }
        this._password = newPassword;
    }

}
   
internal class Program
{
    private static void Main(string[] args)
    {
        UserAccount user1 = new UserAccount("JohnDoe", "password123","hadia@gmail.com");
        Console.WriteLine($"User Name: {user1.Name}");

    }
    }
