using System;
using System.Collections;
using System.Diagnostics.Metrics;
using System.Linq;
using System.Text;
class Vehicle
{
    public string brand { get; set; }
    public string model { get; set; }
    public int year { get; set; }

    public void Start()
    {
        Console.WriteLine("Vehicle is starting...");
    }
    public void Stop()
    {
        Console.WriteLine("Vehicle is stopping...");
    }
    public void Fuel()
    {
        Console.WriteLine("Vehicle is refueling...");
    }
    public void DisplayInfo()
    {
        Console.WriteLine($"Brand: {brand}, Model: {model}, Year: {year}");
    }
    public void Drive()
    {
        Console.WriteLine("Vehicle is driving...");
    }
    public Vehicle( string brand, string model, int year )
    {
        this.brand = brand;
        this.model = model;
        this.year = year;
    }
}
class Car : Vehicle 
{
    public Car(string brand, string model, int year, int numberOfDoors) : base(brand, model, year)
    {
        this.numberOfDoors = numberOfDoors;
    }
    public int numberOfDoors { get; set; }
    public void OpenTrunk()
    {
        Console.WriteLine("Car trunk is open...");
    }
}
class Motorcycle : Vehicle
{
        public Motorcycle() : base("MG", "DefaultModel", 2000)
        {
        }
    public bool hasSidecar { get; set; }
    public void PopWheelie()
    {
        Console.WriteLine("Motorcycle is popping a wheelie...");
    }
}
internal class Program
{
    private static void Main(string[] args)
    {
      Vehicle myCar = new Car("Toyota", "Camry", 2020, 4);
      Car myCar2 = new Car ("Honda", "Civic", 2021, 4);
      Motorcycle myMotorcycle = new Motorcycle();
     Console.WriteLine(myCar2.brand);
     Console.WriteLine(myCar2.model);
     Console.WriteLine(myMotorcycle.brand);

    }
}
