using System;
using System.Collections;
using System.Diagnostics.Metrics;
using System.Linq;
using System.Net.Mail;
using System.Text;

abstract class Notification
{
    abstract public void Send();
}
class Email : Notification
{   
    public string Subject { get; set; }
    public override void Send()
    {
        Console.WriteLine("Email sent");
    }
}
class SMS : Notification
{
    public string PhoneNumber { get; set; }
    public override void Send()
    {
        Console.WriteLine("SMS sent");
    }
}
class Push : Notification
{
    public string DeviceToken { get; set; }
    public override void Send()
    {
        Console.WriteLine("Push notification sent");
    }
}
class NotificationServive
{
    public static Notification CreateNotification(string type)
    {
       
        if (type.Equals("Email", StringComparison.OrdinalIgnoreCase))
        {
            return new Email();
        }
       else if (type.Equals("SMS", StringComparison.OrdinalIgnoreCase))
        {
            return new SMS();
        }
       else if (type.Equals("Push", StringComparison.OrdinalIgnoreCase))
        {
            return new Push();
        }
        else
        {
            throw new ArgumentException("Invalid notification type");
        }
    }
}
internal class Program
{
    private static void Main(string[] args)
    {
        Notification notification1 = NotificationServive.CreateNotification("Email");
        notification1.Send();
        Notification notification2 = new Email();
        notification2.Send();
    }
}
